# Gemini API key — get yours free at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Restrict CORS origin for API calls (set to your Vercel URL in production)
# Leave as * for local development
ALLOWED_ORIGIN=*

# GitHub Personal Access Token with 'repo' scope
# Used by /api/update-accidents to commit updated accidents.json back to the repo
GITHUB_TOKEN=your_github_pat_here

# GitHub repo in owner/repo format (e.g. tanasatit/Accident-event)
GITHUB_REPO=your_github_username/your_repo_name

# Branch to commit updated data to (defaults to main)
GITHUB_BRANCH=main

# Random secret to protect the /api/update-accidents cron endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
